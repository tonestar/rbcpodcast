{
  "name": "astropod",
  "description": "Astropod is a free and open-source serverless podcast template. Host your podcast for free using online third-party services.",
  "type": "module",
  "author": "Manuel Ernesto Garcia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "cms": "netlify-cms-proxy-server",
    "dev:cms": "concurrently \"npm run dev\" \"npm run cms\"",
    "sermons:discover": "node scripts/scrape-sermons.mjs --discover",
    "sermons:upload": "node scripts/scrape-sermons.mjs",
    "sermons:list": "node scripts/scrape-sermons.mjs --list-series",
    "sermons:stats": "node -e \"const m=JSON.parse(require('fs').readFileSync('scripts/sermon-manifest.json'));const s={};m.forEach(e=>s[e.status]=(s[e.status]??0)+1);console.log(s)\"",
    "sermons:skipped": "node -e \"const m=JSON.parse(require('fs').readFileSync('scripts/sermon-manifest.json'));m.filter(e=>e.status==='skipped').forEach(e=>console.log(e.date,e.title))\"",
    "sermons:verify": "node scripts/scrape-sermons.mjs --verify",
    "sermons:fix-metadata": "node scripts/scrape-sermons.mjs --fix-metadata",
    "sermons:upload-all": "node scripts/scrape-sermons.mjs --upload-all",
    "sermons:generate": "node scripts/generate-episodes.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/sitemap": "^3.0.0",
    "astro": "^5.0.0",
    "daisyui": "^5.5.19",
    "dayjs": "^1.11.9",
    "marked": "^7.0.2",
    "marked-plaintext": "^0.0.2",
    "sharp": "^0.32.6",
    "xml2js": "^0.6.2"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": [
        "current",
        "linux"
      ],
      "cpu": [
        "current",
        "x64"
      ],
      "libc": [
        "current",
        "glibc"
      ]
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1018.0",
    "@tailwindcss/typography": "^0.5.9",
    "@tailwindcss/vite": "^4.0.0",
    "astro-robots-txt": "^0.5.0",
    "cheerio": "^1.2.0",
    "concurrently": "^9.0.0",
    "music-metadata": "^11.12.3",
    "netlify-cms-proxy-server": "^1.3.0",
    "tailwindcss": "^4.0.0"
  }
}
